<?xml version="1.0" encoding="utf-8"?>
<odoo><data noupdate="1">

        <!-- Sequences for sale.credit -->
        <record id="seq_sale_credit" model="ir.sequence">
            <field name="name">Financiamiento</field>
            <field name="code">sale.credit</field>
            <field name="prefix">SC/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequences for sale.credit -->
        <record id="seq_sale_credit_payment" model="ir.sequence">
            <field name="name">Recibido Ingreso</field>
            <field name="code">sale.credit.payment</field>
            <field name="prefix">RI/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        
        <!-- Sequence for sale.credit.charge -->
        <record id="seq_sale_credit_charge" model="ir.sequence">
            <field name="name">Cargo/Abono</field>
            <field name="code">sale.credit.charge</field>
            <field name="prefix">CA/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
