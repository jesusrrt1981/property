<?xml version='1.0' encoding='utf-8'?>
<odoo><data noupdate="0">
        <record id="category_module_credito" model="ir.module.category">
            <field name="name">Financiamiento</field>
            <field name="description">Helps you handle your accounting needs, if you are not an accountant, we suggest you to install only the Invoicing.</field>
            <field name="sequence">7</field>
        </record>
        <record id="group_credit_user" model="res.groups">
            <field name="name">Usuario</field>
            <field name="category_id" ref="category_module_credito"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="group_credit_manager" model="res.groups">
            <field name="name">Administrador</field>
            <field name="category_id" ref="category_module_credito"/>
            <field name="implied_ids" eval="[(4, ref('group_credit_user'))]"/>
        </record>
        <record id="group_maintenance_period_generator" model="res.groups">
            <field name="name">Generate Annual Maintenance</field>
            <field name="category_id" ref="category_module_credito"/>
            <field name="implied_ids" eval="[(4, ref('group_credit_user'))]"/>
            <field name="comment">May generate one to five annual maintenance charges.</field>
        </record>
        <record id="group_sale_credit_other_permissions" model="res.groups">
            <field name="name">Otros Permisos de Crédito de Venta</field>
            <field name="category_id" ref="category_module_credito"/>
            <field name="implied_ids" eval="[(4, ref('group_credit_user'))]"/>
        </record>

        <!-- Grupo: Oficial de Cobro -->
        <record id="group_collection_officer" model="res.groups">
            <field name="name">Oficial de Cobro</field>
            <field name="category_id" ref="category_module_credito"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Puede ver y gestionar solo los contratos asignados como oficial.</field>
        </record>

        <!-- Grupo: Gerente de Cobros -->
        <record id="group_collection_manager" model="res.groups">
            <field name="name">Gerente de Cobros</field>
            <field name="category_id" ref="category_module_credito"/>
            <field name="implied_ids" eval="[(4, ref('group_collection_officer'))]"/>
            <field name="comment">Puede ver todos los contratos de su equipo.</field>
        </record>

        <!-- Grupo: Motorista -->
        <record id="group_motorista" model="res.groups">
            <field name="name">Motorista</field>
            <field name="category_id" ref="category_module_credito"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Puede ver avisos de cobro asignados y registrar pagos.</field>
        </record>
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('group_credit_manager'))]"/>
        </record>

        <record id="base.default_user" model="res.users">
            <field name="groups_id" eval="[(4,ref('group_credit_manager'))]"/>
        </record>
    </data>
</odoo>
