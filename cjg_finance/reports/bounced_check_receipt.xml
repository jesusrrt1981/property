<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_report_bounced_check_receipt" model="ir.actions.report">
            <field name="name">Recibo Cheque Devuelto</field>
            <field name="model">sale.credit.payment</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">cjg_finance.report_bounced_check_receipt</field>
            <field name="report_file">cjg_finance.report_bounced_check_receipt</field>
            <field name="print_report_name">'Cheque Devuelto - %s' % (object.name)</field>
        </record>

        <!-- Formato Testarossa: modulos/caja/print/recibo_cheque_devuelto.php -->
        <template id="report_bounced_check_receipt">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <div class="text-center mb-3">
                                <h4>RECIBO DE CHEQUE DEVUELTO</h4>
                            </div>

                            <table class="table table-sm table-bordered">
                                <tr>
                                    <td style="width:25%"><strong>Recibo Original</strong></td>
                                    <td style="width:25%"><span t-field="doc.name"/></td>
                                    <td style="width:25%"><strong>Fecha Devolución</strong></td>
                                    <td style="width:25%"><span t-field="doc.bounce_date"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Contrato</strong></td>
                                    <td><span t-field="doc.credit_id.name"/></td>
                                    <td><strong>Cliente</strong></td>
                                    <td><span t-field="doc.credit_id.partner_id.name"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Cheque No.</strong></td>
                                    <td><span t-field="doc.bounce_check_number"/></td>
                                    <td><strong>Banco</strong></td>
                                    <td><span t-field="doc.bounce_bank"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Motivo</strong></td>
                                    <td colspan="3"><span t-field="doc.bounce_reason"/></td>
                                </tr>
                            </table>

                            <table class="table table-sm mt-3" style="width: 50%; margin-left: auto;">
                                <tr>
                                    <td><strong>Monto del Pago Revertido:</strong></td>
                                    <td class="text-end">
                                        <span t-esc="doc.amount_total"
                                              t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Cargo por Devolución:</strong></td>
                                    <td class="text-end">
                                        <span t-esc="doc.bounce_fee"
                                              t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                    </td>
                                </tr>
                                <tr style="border-top: 2px solid #000;">
                                    <td><strong>TOTAL ADEUDADO:</strong></td>
                                    <td class="text-end">
                                        <strong>
                                            <span t-esc="(doc.amount_total or 0.0) + (doc.bounce_fee or 0.0)"
                                                  t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                        </strong>
                                    </td>
                                </tr>
                            </table>

                            <p class="mt-3 text-muted">
                                Las cuotas cubiertas por este pago han vuelto a estado pendiente.
                            </p>

                            <div class="row mt-5 pt-4">
                                <div class="col-6 text-center">
                                    <div style="border-top: 1px solid #000; margin: 0 40px;">Cajero</div>
                                </div>
                                <div class="col-6 text-center">
                                    <div style="border-top: 1px solid #000; margin: 0 40px;">Cliente</div>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>
