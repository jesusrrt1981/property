<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="loan_calc_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Reporte de Préstamo: </h2>
                        <table class="table table-condensed">
                            <thead>
                                <tr>
                                    <th>Fecha de Pago</th>
                                    <th>Saldo Inicial</th>
                                    <th>Capital</th>
                                    <th>Interés</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.loan_calc_line_ids" t-as="line">
                                    <td><t t-esc="line.due_date"/></td>
                                    <td><t t-esc="line.saldo_inicial"/></td>
                                    <td><t t-esc="line.principal"/></td>
                                    <td><t t-esc="line.interest"/></td>
                                    <td><t t-esc="line.total"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
    </data>
</odoo>
