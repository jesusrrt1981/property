<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_maintenance_period_generate_wizard" model="ir.ui.view">
        <field name="name">maintenance.period.generate.wizard.form</field>
        <field name="model">maintenance.period.generate.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Annual Maintenance">
                <group>
                    <field name="contract_id"/>
                    <field name="years"/>
                </group>
                <footer>
                    <button name="action_generate" type="object" string="Generate" class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
