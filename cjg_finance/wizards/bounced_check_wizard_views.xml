<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bounced_check_wizard_form" model="ir.ui.view">
            <field name="name">bounced.check.wizard.form</field>
            <field name="model">bounced.check.wizard</field>
            <field name="arch" type="xml">
                <form string="Registrar Cheque Devuelto">
                    <sheet>
                        <div class="alert alert-warning" role="alert">
                            Esto anulará el pago: las cuotas cubiertas volverán a estado pendiente
                            y se revertirán los asientos contables.
                        </div>
                        <group>
                            <group>
                                <field name="payment_id" options="{'no_create': True}"/>
                                <field name="credit_id"/>
                                <field name="partner_id"/>
                            </group>
                            <group>
                                <field name="bounce_date"/>
                                <field name="check_number"/>
                                <field name="bank"/>
                                <field name="fee_amount"/>
                            </group>
                        </group>
                        <group>
                            <field name="reason"/>
                        </group>
                        <footer>
                            <button name="action_confirm" string="Confirmar Devolución" type="object"
                                    class="btn-danger" confirm="¿Confirma la devolución del cheque? El pago será anulado."/>
                            <button string="Cancelar" class="btn-secondary" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_bounced_check_wizard" model="ir.actions.act_window">
            <field name="name">Registrar Cheque Devuelto</field>
            <field name="res_model">bounced.check.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- Botón en el form del pago + filtro -->
        <record id="view_sale_credit_payment_form_bounced" model="ir.ui.view">
            <field name="name">sale.credit.payment.form.bounced</field>
            <field name="model">sale.credit.payment</field>
            <field name="inherit_id" ref="cjg_finance.sale_credit_payment_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="action_open_bounced_check_wizard" type="object"
                            string="Cheque Devuelto" class="btn-warning"
                            invisible="state != 'paid' or bounced_check"
                            groups="cjg_finance.group_credit_manager"/>
                    <button name="print_bounced_check_receipt" type="object"
                            string="Imprimir Recibo Devolución"
                            invisible="not bounced_check"/>
                </xpath>
                <xpath expr="//sheet" position="inside">
                    <group string="Cheque Devuelto" invisible="not bounced_check">
                        <group>
                            <field name="bounced_check" readonly="1"/>
                            <field name="bounce_date" readonly="1"/>
                            <field name="bounce_check_number" readonly="1"/>
                        </group>
                        <group>
                            <field name="bounce_bank" readonly="1"/>
                            <field name="bounce_fee" readonly="1"/>
                            <field name="bounce_reason" readonly="1"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
