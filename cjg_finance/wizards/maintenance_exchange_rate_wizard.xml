<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_maintenance_exchange_rate_wizard_form" model="ir.ui.view">
        <field name="name">maintenance.exchange.rate.wizard.form</field>
        <field name="model">maintenance.exchange.rate.wizard</field>
        <field name="arch" type="xml">
            <form string="Actualizar Tasa de Mantenimiento">
                <group>
                    <field name="use_manual_exchange_rate"/>
                    <field name="manual_exchange_rate" invisible="not use_manual_exchange_rate" required="use_manual_exchange_rate"/>
                </group>
                <footer>
                    <button name="action_apply" string="Aplicar" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_maintenance_exchange_rate_wizard" model="ir.actions.act_window">
        <field name="name">Actualizar Tasa</field>
        <field name="res_model">maintenance.exchange.rate.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_maintenance_contract"/>
        <field name="binding_view_types">list,form</field>
    </record>
</odoo>
