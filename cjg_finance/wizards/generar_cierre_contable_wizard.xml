<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_generar_cierre_contable_wizard_form" model="ir.ui.view">
            <field name="name">generar.cierre.contable.wizard.form</field>
            <field name="model">generar.cierre.contable.wizard</field>
            <field name="arch" type="xml">
                <form string="Generar Año de Cierres Contables">
                    <group>
                        <field name="ano"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="sobreescribir_existentes"/>
                    </group>
                    <footer>
                        <button name="action_generar" string="Generar" type="object" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
