<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sale_credit_frequency_view_form" model="ir.ui.view">
            <field name="name">sale.credit.frequency.view.form</field>
            <field name="model">sale.credit.frequency</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="type"/>
                            </group>
                            <group>
                                <field name="interval" style="width:20%;"/>
                            </group>
                        </group>
                        <group>
                            <field name="installment_ids" widget="many2many_tags" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="sale_credit_frequency_view_tree" model="ir.ui.view">
            <field name="name">sale.credit.frequency.view.tree</field>
            <field name="model">sale.credit.frequency</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="type"/>
                </tree>
            </field>
        </record>
    </data>
</odoo>