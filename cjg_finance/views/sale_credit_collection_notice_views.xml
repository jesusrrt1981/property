<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_sale_credit_collection_notice_form" model="ir.ui.view">
            <field name="name">sale.credit.collection.notice.form</field>
            <field name="model">sale.credit.collection.notice</field>
            <field name="arch" type="xml">
                <form string="Aviso de Cobro">
                    <header>
                        <button name="action_assign" string="Asignar" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_print" string="Imprimir" type="object" class="btn-primary" invisible="state == 'draft'"/>
                        <button name="action_mark_delivered" string="Marcar Entregado" type="object" invisible="state != 'assigned'"/>
                        <button name="action_mark_collected" string="Marcar Cobrado" type="object" invisible="state != 'delivered'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,assigned,delivered,collected"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="credit_id" readonly="state != 'draft'"/>
                                <field name="partner_id"/>
                                <field name="official_id"/>
                            </group>
                            <group>
                                <field name="date" readonly="state != 'draft'"/>
                                <field name="collector_id" readonly="state in ['delivered', 'collected', 'cancelled']"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Detalle de Cobro">
                                <field name="line_ids" readonly="state != 'draft'">
                                    <tree editable="bottom">
                                        <field name="description"/>
                                        <field name="amount" sum="Total"/>
                                        <field name="credit_line_id" optional="hide"/>
                                    </tree>
                                </field>
                                <group class="oe_subtotal_footer oe_right">
                                    <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </group>
                            </page>
                            <page string="Notas">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_sale_credit_collection_notice_tree" model="ir.ui.view">
            <field name="name">sale.credit.collection.notice.tree</field>
            <field name="model">sale.credit.collection.notice</field>
            <field name="arch" type="xml">
                <tree string="Avisos de Cobro" decoration-info="state == 'draft'" decoration-warning="state == 'assigned'" decoration-success="state == 'collected'">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="credit_id"/>
                    <field name="partner_id"/>
                    <field name="collector_id"/>
                    <field name="amount_total" sum="Total"/>
                    <field name="state" widget="badge"/>
                </tree>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_sale_credit_collection_notice_search" model="ir.ui.view">
            <field name="name">sale.credit.collection.notice.search</field>
            <field name="model">sale.credit.collection.notice</field>
            <field name="arch" type="xml">
                <search string="Buscar Avisos de Cobro">
                    <field name="name"/>
                    <field name="credit_id"/>
                    <field name="partner_id"/>
                    <field name="collector_id"/>
                    <filter string="Mis Asignados" name="my_assigned" domain="[('collector_id.user_id', '=', uid)]"/>
                    <filter string="Borrador" name="draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Asignados" name="assigned" domain="[('state', '=', 'assigned')]"/>
                    <group expand="0" string="Agrupar Por">
                        <filter string="Motorizado" name="group_collector" context="{'group_by': 'collector_id'}"/>
                        <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                        <filter string="Fecha" name="group_date" context="{'group_by': 'date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_sale_credit_collection_notice" model="ir.actions.act_window">
            <field name="name">Avisos de Cobro</field>
            <field name="res_model">sale.credit.collection.notice</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crear un nuevo Aviso de Cobro
                </p>
            </field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_sale_credit_collection_notice"
                  name="Avisos de Cobro"
                  parent="sale_credit_menu"
                  action="action_sale_credit_collection_notice"
                  sequence="10"/>
    </data>
</odoo>
