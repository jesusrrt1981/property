<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sale_credit_category_action" model="ir.actions.act_window">
            <field name="name">Categorías</field>
            <field name="res_model">sale.credit.category</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="sale_credit_nivel_action" model="ir.actions.act_window">
            <field name="name">Nivel de seguimiento</field>
            <field name="res_model">sale_credit.followup.line</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="sale_credit_installment_action" model="ir.actions.act_window">
            <field name="name">Cuotas</field>
            <field name="res_model">sale.credit.installment</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="sale_credit_frequency_action" model="ir.actions.act_window">
            <field name="name">Frecuencia</field>
            <field name="res_model">sale.credit.frequency</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="sale_credit_action" model="ir.actions.act_window">
            <field name="name">Solicitud Créditos</field>
            <field name="res_model">sale.credit</field>
            <field name="view_mode">tree,form,graph</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Crear un nuevo Credito</p>
            </field>
        </record>

        <record id="sale_credit_my_action" model="ir.actions.act_window">
            <field name="name">Mis Contratos</field>
            <field name="res_model">sale.credit</field>
            <field name="view_mode">tree,form,graph</field>
            <field name="domain">[("user_id", "=", uid)]</field>
        </record>

        <record id="sale_credit_my_portfolio_action" model="ir.actions.act_window">
            <field name="name">Mi Cartera</field>
            <field name="res_model">sale.credit</field>
            <field name="view_mode">tree,form,graph</field>
            <field name="context">{
                'search_default_my_portfolio': 1,
                'search_default_approved': 1
            }</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No tienes contratos asignados</p>
                <p>Los contratos donde eres el oficial asignado aparecerán aquí.</p>
            </field>
        </record>

        <record id="sale_credit_overdue_action" model="ir.actions.act_window">
            <field name="name">Contratos con atraso</field>
            <field name="res_model">sale.credit</field>
            <field name="view_mode">tree,form,graph</field>
            <field name="domain">[("has_overdue", "=", True)]</field>
        </record>

        <record id="credit_overdue_history_action" model="ir.actions.act_window">
            <field name="name">Historial de Moras de Créditos</field>
            <field name="res_model">credit.overdue.history</field>
            <field name="view_mode">tree,form</field>
        </record>
        <!-- Commented out duplicate record -->
        <record id="res_config_setting_action" model="ir.actions.act_window">
            <field name="name">Configuracion de credito</field>
            <field name="res_model">res.config.settings</field>
            <field name="view_id" ref="cjg_finance_settings_view_form" />
            <field name="view_mode">form</field>
            <field name="target">inline</field>
            <field name="context">{'module' : 'cjg_finance'}</field>
        </record>

        <record id="credit_overdue_action" model="ir.actions.act_window">
            <field name="name">Moras de Crédito</field>
            <field name="res_model">credit.overdue</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="sale_credit_line_action" model="ir.actions.act_window">
            <field name="name">Líneas de Créditos</field>
            <field name="res_model">sale.credit.line</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="sale_credit_payment_action" model="ir.actions.act_window">
            <field name="name">Pagos</field>
            <field name="res_model">sale.credit.payment</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Crear un Pago</p>
            </field>
        </record>
        <!-- Menús principales separados por dominio operativo.
             Gestion Contratos conserva ventas/contratos; Cobros agrupa cartera,
             pagos, mora, actas y dashboards de cobranza para poder asignar
             accesos sin exponer toda la operación comercial. -->
        <menuitem id="credito_menu" name="Gestion Contratos" groups="cjg_finance.group_credit_user,cjg_finance.group_credit_manager" web_icon="cjg_finance,static/description/icon.png" sequence="40" />

        <menuitem id="menu_cobros_root"
                  name="Gestión de Cobranza"
                  groups="cjg_finance.group_collection_officer,cjg_finance.group_collection_manager,cjg_finance.group_credit_manager"
                  web_icon="cjg_finance,static/description/icon.png"
                  sequence="41" />

        <menuitem id="sale_credit_menu" name="Créditos" sequence="5" parent="credito_menu" />

        <record id="credit_res_partner_action" model="ir.actions.act_window">
            <field name="name">Clientes</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="domain">[("customer_rank", ">", 0)]</field>
        </record>

        <menuitem id="credit_partner_menu" name="Clientes" parent="credito_menu" action="credit_res_partner_action" sequence="10" />

        <menuitem id="finance_dashboard_menu" name="Dashboard" parent="credito_menu" action="action_finance_dashboard" sequence="0" />

        <menuitem id="sale_credit_sub_menu" name="Créditos" action="sale_credit_action" parent="sale_credit_menu" sequence="1" />

        <menuitem id="sale_credit_my_menu" name="Mis Contratos" action="sale_credit_my_action" parent="sale_credit_menu" sequence="3" />

        <menuitem id="menu_cobros_cartera" name="Cartera" parent="menu_cobros_root" sequence="10" groups="cjg_finance.group_collection_officer,cjg_finance.group_collection_manager,cjg_finance.group_credit_manager"/>

        <menuitem id="sale_credit_my_portfolio_menu" name="Mi Cartera" action="sale_credit_my_portfolio_action" parent="menu_cobros_cartera" sequence="10" groups="cjg_finance.group_collection_officer,cjg_finance.group_collection_manager,cjg_finance.group_credit_manager" />

        <menuitem id="sale_credit_overdue_menu" name="Contratos con Atraso" action="sale_credit_overdue_action" parent="menu_cobros_cartera" sequence="20" groups="cjg_finance.group_collection_officer,cjg_finance.group_collection_manager,cjg_finance.group_credit_manager" />

        <menuitem id="sale_credit_line_menu" name="Líneas de Créditos" action="sale_credit_line_action" parent="sale_credit_menu" sequence="2" />
        <!-- Configuracion -->
        <menuitem id="credito_configuracion" name="Configuración" sequence="99" parent="credito_menu" />

        <menuitem id="sale_credit_frequency_menu" name="Frecuencia" parent="credito_configuracion" action="sale_credit_frequency_action" sequence="2" />

        <menuitem id="sale_credit_category_menu" name="Categoría" parent="credito_configuracion" action="sale_credit_category_action" sequence="3" />

        <menuitem id="sale_credit_nivel_menu" name="Nivel seguimiento" parent="credito_configuracion" action="sale_credit_nivel_action" sequence="7" />

        <menuitem id="sale_credit_installment_menu" name="Cuotas" parent="credito_configuracion" action="sale_credit_installment_action" sequence="4" />

        <menuitem id="credit_overdue_history_menu" name="Historial de Moras" parent="credito_configuracion" action="credit_overdue_history_action" sequence="5" />

        <menuitem id="res_config_setting_menu" name="Configuración General" parent="credito_configuracion" action="res_config_setting_action" sequence="6" />
        
        <record id="contract_series_sequence_action" model="ir.actions.act_window">
            <field name="name">Secuencias de Contrato</field>
            <field name="res_model">ir.sequence</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('code', 'ilike', 'sale.credit.series.')]</field>
            <field name="context">{}</field>
        </record>
        <menuitem id="contract_series_sequence_menu" name="Secuencias de Contrato" parent="credito_configuracion" action="contract_series_sequence_action" sequence="7" />

        <menuitem id="pagos_menu" name="Pagos" sequence="20" parent="menu_cobros_root" groups="cjg_finance.group_collection_officer,cjg_finance.group_collection_manager,cjg_finance.group_credit_manager" />

        <menuitem id="credit_overdue_menu" name="Moras de Crédito" parent="pagos_menu" action="credit_overdue_action" sequence="1" />

        <menuitem id="sale_credit_adjustment_menu" name="Ajustes (NC/ND)" parent="pagos_menu" action="action_sale_credit_adjustment" sequence="10" />

        <menuitem id="payment_menu" name="Pagos Contratos" action="sale_credit_payment_action" parent="pagos_menu" sequence="2" />

        <menuitem id="customer_credit_statements_menu" name="Seguimiento de Crédito" parent="menu_cobros_root" action="credit_followup_action" sequence="30" groups="cjg_finance.group_collection_officer,cjg_finance.group_collection_manager,cjg_finance.group_credit_manager" />
    
        <!-- Calculadora -->
        <menuitem id="credit_calc_menu" name="Calculadora" parent="credito_menu" groups="cjg_finance.group_credit_user,cjg_finance.group_credit_manager" sequence="40" />


    </data>
</odoo>
