<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
     <record id="view_sale_credit_followup_line_tree" model="ir.ui.view">
        <field name="name">sale_credit.followup.line.tree</field>
        <field name="model">sale_credit.followup.line</field>
        <field name="arch" type="xml">
            <tree string="Follow-up Steps">
                <field name="name"/>
                <field name="delay"/>
                <field name="send_email"/>
                <field name="send_sms"/>
                <field name="auto_execute"/>
                <field name="activity_type_id" string="Activity"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <record id="view_sale_credit_followup_line_form" model="ir.ui.view">
        <field name="name">sale_credit.followup.line.form</field>
        <field name="model">sale_credit.followup.line</field>
        <field name="arch" type="xml">
            <form string="Follow-up Steps">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. First Reminder Email"/></h1>
                    </div>
                    <div class="oe_inline">
                        Remind <field name="delay" class="oe_inline"/> days after due date<label for="delay" string=""/>
                    </div>
                    <notebook>
                        <page string="Notification" name="notification">
                            <group col="3">
                                <group string="Actions" name="actions" colspan="2" col="3">
                                    <group colspan="1">
                                        <field name="send_email"/>
                                        <field name="send_sms"/>
                                    </group>
                                    <group colspan="2">
                                        <field name="mail_template_id" string="Content Template" invisible="not send_email"/>
                                        <field name="sms_template_id" invisible="not send_sms"/>
                                    </group>
                                </group>
                                <group string="Options" name="options" colspan="1">
                                    <field name="auto_execute"/>
                                    <field name="join_invoices" invisible="not send_email"/>
                                </group>
                            </group>
                        </page>
                        <page string="Activity" name="activity">
                            <group>
                                <group name="options">
                                    <field name="create_activity"/>
                                    <field name="activity_default_responsible_type" invisible="not create_activity"/>
                                </group>
                                <group name="notes" invisible="not create_activity">
                                    <field name="activity_type_id" required="create_activity"/>
                                    <field name="activity_summary" required="create_activity"/>
                                </group>
                                <field name="activity_note" nolabel="1" placeholder="Activity Notes" invisible="not create_activity"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción del wizard de recordatorio manual -->
    <record id="credit_manual_reminder_action" model="ir.actions.act_window">
        <field name="name">Enviar Recordatorio Manual</field>
        <field name="res_model">sale_credit.followup</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="customer_credit_statements_form_view" model="ir.ui.view">
            <field name="name">customer.credit.statements.followup</field>
            <field name="model">sale_credit.followup</field>
            <field name="arch" type="xml">
                <form create="false" delete="false">
                  <header>
                        <button string="Seguimiento" name="%(credit_manual_reminder_action)d" type="action" class="button btn-primary"/>
                        <button string="Seguimiento" name="%(credit_manual_reminder_action)d" type="action" class="button btn-secondary" invisible="followup_status_sale_credit == 'in_need_of_action'"/>
                        <field name="followup_line_id_sale_credit" widget="statusbar" options="{'clickable': '1'}"/>
                    </header>
                    <sheet>
                    <div class="oe_button_box" name="button_box">
                            <!-- <button class="oe_stat_button" type="object" name="get_formview_action"
                                    icon="fa-user">
                                Customer
                            </button>
                            <button class="oe_stat_button" type="object" name="action_view_unpaid_invoices"
                                    icon="fa-pencil-square-o">
                                <field string="Invoices" name="unpaid_invoices_count" widget="statinfo"/>
                            </button> -->
                        </div>
                        <field name="followup_status_sale_credit" invisible="1"/>
                        <widget name="web_ribbon" title="In need of action" bg_color="bg-danger" invisible="followup_status_sale_credit != 'in_need_of_action'"/>
                        <widget name="web_ribbon" title="With overdue invoices" bg_color="bg-warning" invisible="followup_status_sale_credit != 'with_overdue_invoices'"/>
                        <div class="oe_title">
                            <h1>
                            <field name="respatner" readonly="True" required="True" class="oe_inline"/> 
                            </h1>
                        </div>
                         <group name="schedule">
                            <group>
                                <field name="sale_credit_reminder_type" widget="radio" options="{'horizontal': true}"/>
                                <field name="followup_responsible_id_sale_credit"/>
                            </group>
                            <group>
                                <field name="sale_credit_next_action_date"/>
                            </group>
                        </group>
                        <field name="count_line" invisible="1"/>
                         <field name="unreconciled_aml_ids_sale_credit">
                            <tree create="false" delete="true" editable="bottom" default_order="days_overdue" no_open="true">
                               <field name="count" readonly="1"/>
                                <field name="credit_id" readonly="1"/>
                               <field name="expected_date_payment" optional="show" widget="remaining_days" readonly="1"/>
                               <field name="internal_notes" optional="show" placeholder="This notes will be used for internal interest..."/>
                               <field name="user_id"/>
                               <field name="partner_id" widget="many2one_clickable" optional="hide" readonly="1"/>
                                <field name="co_debtor_id" widget="many2one_clickable" optional="hide" readonly="1"/>
                               
                                <field name="can_be_dist" string="Aplicar mora?" optional="show" widget="boolean_toggle"/>
                                <field name="days_overdue"/>
                                <field name="amount_residual" string="Residual Amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </tree>
                        </field>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
     </record>

        <record id="customer_credit_statements_tree_view" model="ir.ui.view">
            <field name="name">customer.credit.statements.tree</field>
            <field name="model">sale_credit.followup</field>
            <field name="arch" type="xml">
                <tree string="Follow-up Reports Tree View" create="false" import="false" delete="false" sample="1">
             
                <!--   -->
                    <!-- <field name="currency_id" invisible='1'/> -->
                    <field name="respatner"/>
                    <groupby name="respatner"/>
                    <field name="followup_responsible_id_sale_credit" widget="many2one_avatar_user"/>
                    <!-- <field name="user_id" widget="many2one_avatar_user" optional="hide"/> -->
                    <field name="sale_credit_reminder_type"/>
                    <field name="followup_status_sale_credit" widget="badge" decoration-danger="followup_status_sale_credit == 'in_need_of_action'" decoration-warning="followup_status_sale_credit == 'with_overdue_invoices'" decoration-info="followup_status_sale_credit == 'no_action_needed'"/>
                    <field name="sale_credit_next_action_date" optional="show" widget="remaining_days"/>
                    <field name="followup_line_id_sale_credit"/>
                    <field name="total_due_sale_credit" widget="monetary" options="{'currency_field': 'currency_id'}" sum="Total"/>
                    <field name="total_overdue_sale_credit" widget="monetary" options="{'currency_field': 'currency_id'}" sum="Total"/>
                    <!-- <field name="company_id" groups="base.group_multi_company"/> -->
                    <field name="activity_ids" widget="list_activity"/>
                </tree>
            </field>
        </record>

        <record id="sale_credit_followup_search_view" model="ir.ui.view">
            <field name="name">sale_credit.followup.search</field>
            <field name="model">sale_credit.followup</field>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="respatner"/>
                    <field name="credit_id"/>
                    <field name="user_id"/>
                    
                    <filter string="Overdue Invoices" name="filter_with_overdue_invoices" domain="[('followup_status_sale_credit', 'in', ('in_need_of_action', 'with_overdue_invoices'))]"/>
                    <filter string="In need of action" name="filter_in_need_of_action" domain="[('followup_status_sale_credit', '=', 'in_need_of_action')]"/>
                    <separator/>
                    <group expand="0" name="group_by" string="Group By">
                        <filter name="salesperson" string="Salesperson" domain="[]" context="{'group_by' : 'respatner'}"/>
                        <!-- <filter name="group_country" string="Country" context="{'group_by': 'country_id'}"/> -->
                    </group>  
                    <!-- <groupby name="respatner"/> -->
                    <!-- <filter string="Clientes"
                            name="filter_assigned_to_me"
                            domain="[('respatner', '=',respatner )]">
                    </filter> -->
                </search>
            </field>
        </record>

        
       <record id="credit_followup_action" model="ir.actions.act_window">
            <field name="name">Seguimiento de credito</field>
            <field name="res_model">sale_credit.followup</field>
            <field name="view_mode">tree,form</field>
             <field name="search_view_id" ref="sale_credit_followup_search_view"/>
             <field name="context">{'group_by' : 'respatner'}</field>
             <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                No follow-up to send!
              </p>
            </field>
        </record>
        
        <!-- <menuitem 
            id="customer_credi_statements_menu" 
            name="Seguimiento de credito"          
            parent="credito_menu"
            action="action_view_list_customer_followup_credit" 
            sequence="20"
        /> -->


    </data>
</odoo>
