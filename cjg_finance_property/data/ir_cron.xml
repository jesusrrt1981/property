<?xml version="1.0" encoding="utf-8" ?>
<odoo><data noupdate="1">
        <record id="sale_recurring_invoice" model="ir.cron">
            <field name="name">Rental Management: Sale Recurring Invoice</field>
            <field name="model_id" ref="cjg_finance_property.model_property_vendor"/>
            <field name="state" eval="'code'"/>
            <field name="code" eval="'model.sale_recurring_invoice()'"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">1</field>
            <field name="active" eval="True"/>
            <field name="doall" eval="True"/>
        </record>
        <record id="parent_property_address_update" model="ir.cron">
            <field name="name">Rental Management: Parent Property Address</field>
            <field name="model_id" ref="cjg_finance_property.model_property_details"/>
            <field name="state" eval="'code'"/>
            <field name="code" eval="'model.update_property_address()'"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">1</field>
            <field name="active" eval="False"/>
            <field name="doall" eval="True"/>
        </record>
    </data>
</odoo>